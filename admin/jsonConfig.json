{
	"i18n": true,
	"type": "panel",
	"items": {
		"_connectionSettings": {
			"type": "header",
			"text": "Connection Settings",
			"size": 3
		},
		"server": {
			"type": "text",
			"label": "server",
			"newLine": true,
			"sm": 12, "md": 6, "lg": 4,
			"help": "URL of the API server"
		},
		"email": {
			"type": "text",
			"label": "email",
			"newLine": true,
			"sm": 12, "md": 6, "lg": 4,
			"help": "Octopus account e-mail address"
		},
		"password": {
			"type": "password",
			"label": "password",
			"newLine": true,
			"sm": 12, "md": 6, "lg": 4,
			"help": "Octopus account password"
		},
		"account": {
			"type": "text",
			"label": "account",
			"newLine": true,
			"sm": 12, "md": 6, "lg": 4,
			"help": "Electricity contract number, leave empty for auto-discovery"
		},
		"_pollingSettings": {
			"type": "header",
			"text": "Polling Settings",
			"size": 3,
			"newLine": true
		},
		"pollInterval": {
			"type": "number",
			"min": 5, "max": 3600,
			"label": "pollInterval",
			"help": "Data update interval in seconds (5–3600)",
			"sm": 4, "xl": 2,
			"default": 60,
			"newLine": true
		},
		"_chargingPreferences": {
			"type": "header",
			"text": "Vehicle Charging Preferences (optional)",
			"size": 3,
			"newLine": true
		},
		"enableChargingPreferences": {
			"type": "checkbox",
			"label": "enableChargingPreferences",
			"help": "Automatically set vehicle charging targets",
			"default": false,
			"newLine": true
		},
		"weekdayTargetSoc": {
			"type": "number",
			"min": 0, "max": 100,
			"label": "weekdayTargetSoc",
			"help": "Target SOC for weekdays (Mon–Fri)",
			"default": 80,
			"newLine": true,
			"hidden": "!data.enableChargingPreferences"
		},
		"weekendTargetSoc": {
			"type": "number",
			"min": 0, "max": 100,
			"label": "weekendTargetSoc",
			"help": "Target SOC for weekends (Sat–Sun)",
			"default": 90,
			"hidden": "!data.enableChargingPreferences"
		},
		"weekdayTargetTime": {
			"type": "text",
			"label": "weekdayTargetTime",
			"help": "Target time for weekday charging, e.g. 07:00",
			"default": "07:00",
			"newLine": true,
			"hidden": "!data.enableChargingPreferences"
		},
		"weekendTargetTime": {
			"type": "text",
			"label": "weekendTargetTime",
			"help": "Target time for weekend charging, e.g. 09:00",
			"default": "09:00",
			"hidden": "!data.enableChargingPreferences"
		},
		"_aiMode": {
			"type": "header",
			"text": "AI Mode – Intelligent Battery Charging (Beta)",
			"size": 3,
			"newLine": true
		},
		"enableAiMode": {
			"type": "checkbox",
			"label": "enableAiMode",
			"help": "AI-based battery charging decisions using weather forecast and PV production",
			"default": false,
			"newLine": true
		},
		"_brightskyAdapter": {
			"type": "header",
			"text": "Weather Forecast (brightsky – Deutscher Wetterdienst)",
			"size": 5,
			"newLine": true,
			"hidden": "!data.enableAiMode && !data.enableSmartCharging"
		},
		"brightskyInstance": {
			"type": "text",
			"label": "brightskyInstance",
			"help": "brightsky adapter instance, e.g. brightsky.0 (Deutscher Wetterdienst)",
			"default": "brightsky.0",
			"newLine": true,
			"hidden": "!data.enableAiMode && !data.enableSmartCharging"
		},
		"_claudeApi": {
			"type": "header",
			"text": "Claude AI Settings",
			"size": 5,
			"newLine": true,
			"hidden": "!data.enableAiMode"
		},
		"claudeApiKey": {
			"type": "password",
			"label": "claudeApiKey",
			"help": "Anthropic Claude API key for AI decisions",
			"newLine": true,
			"hidden": "!data.enableAiMode"
		},
		"claudeModel": {
			"type": "select",
			"label": "claudeModel",
			"options": [
				{"label": "Sonnet (Recommended – Balanced Performance)", "value": "sonnet"},
				{"label": "Haiku (Fast & Economical)", "value": "haiku"}
			],
			"default": "sonnet",
			"hidden": "!data.enableAiMode"
		},
		"_claudeApiHelp": {
			"type": "staticText",
			"text": "claude_api_key_tip",
			"newLine": true,
			"hidden": "!data.enableAiMode"
		},
		"_pvConfiguration": {
			"type": "header",
			"text": "PV System Configuration",
			"size": 5,
			"newLine": true,
			"hidden": "!data.enableAiMode && !data.enableSmartCharging"
		},
		"pvArray1Enabled": {
			"type": "checkbox",
			"label": "pvArray1Enabled",
			"default": true,
			"newLine": true,
			"hidden": "!data.enableAiMode && !data.enableSmartCharging"
		},
		"pvArray1Power": {
			"type": "number",
			"min": 0,
			"label": "pvArray1Power",
			"default": 3,
			"hidden": "(!data.enableAiMode && !data.enableSmartCharging) || !data.pvArray1Enabled"
		},
		"pvArray1Orientation": {
			"type": "select",
			"label": "pvArray1Orientation",
			"options": [
				{"label": "North", "value": "N"}, {"label": "Northeast", "value": "NE"},
				{"label": "East",  "value": "E"}, {"label": "Southeast", "value": "SE"},
				{"label": "South", "value": "S"}, {"label": "Southwest", "value": "SW"},
				{"label": "West",  "value": "W"}, {"label": "Northwest",  "value": "NW"}
			],
			"default": "E",
			"hidden": "(!data.enableAiMode && !data.enableSmartCharging) || !data.pvArray1Enabled"
		},
		"pvArray1Tilt": {
			"type": "number",
			"min": 0, "max": 90,
			"label": "pvArray1Tilt",
			"help": "0 = horizontal, 90 = vertical",
			"default": 0,
			"newLine": true,
			"hidden": "(!data.enableAiMode && !data.enableSmartCharging) || !data.pvArray1Enabled"
		},
		"pvArray2Enabled": {
			"type": "checkbox",
			"label": "pvArray2Enabled",
			"default": true,
			"newLine": true,
			"hidden": "!data.enableAiMode && !data.enableSmartCharging"
		},
		"pvArray2Power": {
			"type": "number",
			"min": 0,
			"label": "pvArray2Power",
			"default": 4.2,
			"hidden": "(!data.enableAiMode && !data.enableSmartCharging) || !data.pvArray2Enabled"
		},
		"pvArray2Orientation": {
			"type": "select",
			"label": "pvArray2Orientation",
			"options": [
				{"label": "North", "value": "N"}, {"label": "Northeast", "value": "NE"},
				{"label": "East",  "value": "E"}, {"label": "Southeast", "value": "SE"},
				{"label": "South", "value": "S"}, {"label": "Southwest", "value": "SW"},
				{"label": "West",  "value": "W"}, {"label": "Northwest",  "value": "NW"}
			],
			"default": "S",
			"hidden": "(!data.enableAiMode && !data.enableSmartCharging) || !data.pvArray2Enabled"
		},
		"pvArray2Tilt": {
			"type": "number",
			"min": 0, "max": 90,
			"label": "pvArray2Tilt",
			"default": 52,
			"newLine": true,
			"hidden": "(!data.enableAiMode && !data.enableSmartCharging) || !data.pvArray2Enabled"
		},
		"pvArray3Enabled": {
			"type": "checkbox",
			"label": "pvArray3Enabled",
			"default": true,
			"newLine": true,
			"hidden": "!data.enableAiMode && !data.enableSmartCharging"
		},
		"pvArray3Power": {
			"type": "number",
			"min": 0,
			"label": "pvArray3Power",
			"default": 1.6,
			"hidden": "(!data.enableAiMode && !data.enableSmartCharging) || !data.pvArray3Enabled"
		},
		"pvArray3Orientation": {
			"type": "select",
			"label": "pvArray3Orientation",
			"options": [
				{"label": "North", "value": "N"}, {"label": "Northeast", "value": "NE"},
				{"label": "East",  "value": "E"}, {"label": "Southeast", "value": "SE"},
				{"label": "South", "value": "S"}, {"label": "Southwest", "value": "SW"},
				{"label": "West",  "value": "W"}, {"label": "Northwest",  "value": "NW"}
			],
			"default": "W",
			"hidden": "(!data.enableAiMode && !data.enableSmartCharging) || !data.pvArray3Enabled"
		},
		"pvArray3Tilt": {
			"type": "number",
			"min": 0, "max": 90,
			"label": "pvArray3Tilt",
			"default": 0,
			"newLine": true,
			"hidden": "(!data.enableAiMode && !data.enableSmartCharging) || !data.pvArray3Enabled"
		},
		"_batteryConfiguration": {
			"type": "header",
			"text": "Battery Configuration",
			"size": 5,
			"newLine": true,
			"hidden": "!data.enableAiMode && !data.enableSmartCharging"
		},
		"batteryCapacity": {
			"type": "number",
			"min": 0,
			"label": "batteryCapacity",
			"help": "Total usable battery capacity",
			"default": 10,
			"newLine": true,
			"hidden": "!data.enableAiMode && !data.enableSmartCharging"
		},
		"batteryMinSoc": {
			"type": "number",
			"min": 0, "max": 100,
			"label": "batteryMinSoc",
			"help": "Minimum battery SOC to maintain",
			"default": 20,
			"hidden": "!data.enableAiMode && !data.enableSmartCharging"
		},
		"acChargePowerKw": {
			"type": "number",
			"min": 0.1, "max": 50,
			"label": "acChargePowerKw",
			"help": "Maximum AC charging power from grid in kW",
			"default": 4.0,
			"newLine": true,
			"hidden": "!data.enableAiMode && !data.enableSmartCharging"
		},
		"_evccIntegration": {
			"type": "header",
			"text": "evcc Adapter Integration",
			"size": 5,
			"newLine": true,
			"hidden": "!data.enableAiMode"
		},
		"evccInstance": {
			"type": "text",
			"label": "evccInstance",
			"help": "evcc adapter instance, e.g. evcc.0",
			"default": "evcc.0",
			"newLine": true,
			"hidden": "!data.enableAiMode"
		},
		"_aiDecisionSettings": {
			"type": "header",
			"text": "AI Decision Settings",
			"size": 5,
			"newLine": true,
			"hidden": "!data.enableAiMode"
		},
		"enableHistoryAnalysis": {
			"type": "checkbox",
			"label": "enableHistoryAnalysis",
			"help": "Use historical data from History adapter for better decisions",
			"default": true,
			"newLine": true,
			"hidden": "!data.enableAiMode"
		},
		"historyAnalysisDays": {
			"type": "number",
			"min": 1, "max": 30,
			"label": "historyAnalysisDays",
			"help": "Number of days to analyze (1–30)",
			"default": 7,
			"newLine": true,
			"hidden": "!data.enableAiMode || !data.enableHistoryAnalysis"
		},
		"aiDecisionTimes": {
			"type": "text",
			"label": "aiDecisionTimes",
			"help": "Decision times per day, e.g. 06:00,17:30",
			"default": "06:00,17:30",
			"newLine": true,
			"hidden": "!data.enableAiMode"
		},
		"_aiDecisionNote": {
			"type": "staticText",
			"text": "ai_decision_tip",
			"newLine": true,
			"hidden": "!data.enableAiMode"
		},
		"_smartChargingPlanner": {
			"type": "header",
			"text": "Smart Charging Planner – Battery Charge Target Calculation",
			"size": 3,
			"newLine": true
		},
		"_smartChargingPlannerDesc": {
			"type": "staticText",
			"text": "smart_charging_desc",
			"newLine": true
		},
		"enableSmartCharging": {
			"type": "checkbox",
			"label": "enableSmartCharging",
			"help": "Calculate daily battery charge target based on PV forecast and pricing",
			"default": false,
			"newLine": true
		},
		"evccUrl": {
			"type": "text",
			"label": "evccUrl",
			"help": "evcc HTTP address, e.g. http://evcc:7070",
			"default": "http://evcc:7070",
			"newLine": true,
			"hidden": "!data.enableSmartCharging"
		},
		"_evccNote": {
			"type": "staticText",
			"text": "evcc_requirement_note",
			"newLine": true,
			"hidden": "!data.enableSmartCharging"
		},
		"smartChargingCalcTime": {
			"type": "text",
			"label": "smartChargingCalcTime",
			"help": "Daily calculation time, e.g. 22:00 (before cheap night phase)",
			"default": "22:00",
			"newLine": true,
			"hidden": "!data.enableSmartCharging"
		},
		"householdConsumptionKw": {
			"type": "number",
			"min": 0.1, "max": 20,
			"label": "householdConsumptionKw",
			"help": "Average household consumption in kW (fallback without historical data)",
			"default": 0.5,
			"newLine": true,
			"hidden": "!data.enableSmartCharging"
		},
		"pvSufficiencyThreshold": {
			"type": "number",
			"min": 0.1, "max": 20,
			"label": "pvSufficiencyThreshold",
			"help": "Min. PV output per hour for solar sufficiency (fallback)",
			"default": 1.0,
			"hidden": "!data.enableSmartCharging"
		},
		"_evccStatesHeader": {
			"type": "header",
			"text": "evcc Data Points & History",
			"size": 5,
			"newLine": true,
			"hidden": "!data.enableSmartCharging"
		},
		"evccBatterySocState": {
			"type": "text",
			"label": "evccBatterySocState",
			"help": "ioBroker state with battery SOC from evcc (JSON object with .soc field, e.g. evcc.0.status.battery)",
			"default": "evcc.0.status.battery",
			"newLine": true,
			"hidden": "!data.enableSmartCharging"
		},
		"evccPvPowerState": {
			"type": "text",
			"label": "evccPvPowerState",
			"help": "ioBroker state with current PV power from evcc, must be logged by history adapter",
			"default": "evcc.0.status.pv",
			"newLine": true,
			"hidden": "!data.enableSmartCharging"
		},
		"evccPowerState": {
			"type": "text",
			"label": "evccPowerState",
			"help": "ioBroker state with home power consumption from evcc, must be logged",
			"default": "evcc.0.status.homePower",
			"newLine": true,
			"hidden": "!data.enableSmartCharging"
		},
		"historyInstance": {
			"type": "text",
			"label": "historyInstance",
			"help": "History adapter instance logging evcc consumption and PV data, e.g. sql.0",
			"default": "sql.0",
			"newLine": true,
			"hidden": "!data.enableSmartCharging && (!data.enableAiMode || !data.enableHistoryAnalysis)"
		},
		"pvConservatismFactor": {
			"type": "number",
			"min": 0.1, "max": 1.0, "step": 0.05,
			"label": "pvConservatismFactor",
			"help": "Share of historical average PV credited (0.75 = 75%)",
			"default": 0.75,
			"newLine": true,
			"hidden": "!data.enableSmartCharging"
		},
		"enableSmartChargingNotification": {
			"type": "checkbox",
			"label": "enableSmartChargingNotification",
			"help": "Send daily charging plan summary via Telegram",
			"default": false,
			"newLine": true,
			"hidden": "!data.enableSmartCharging"
		},
		"_smartChargingMonitoring": {
			"type": "header",
			"text": "Charging Monitoring",
			"size": 3,
			"newLine": true
		},
		"enableChargingMonitoring": {
			"type": "checkbox",
			"label": "enableChargingMonitoring",
			"help": "Alert when smart charging is not active after configured time with low vehicle SOC",
			"default": false,
			"newLine": true
		},
		"monitoringStartTime": {
			"type": "text",
			"label": "monitoringStartTime",
			"help": "Monitoring activation time, e.g. 20:00",
			"default": "20:00",
			"newLine": true,
			"hidden": "!data.enableChargingMonitoring"
		},
		"minVehicleSoc": {
			"type": "number",
			"min": 0, "max": 100,
			"label": "minVehicleSoc",
			"help": "Alert threshold for vehicle state of charge",
			"default": 60,
			"hidden": "!data.enableChargingMonitoring"
		},
		"telegramInstance": {
			"type": "text",
			"label": "telegramInstance",
			"help": "Telegram adapter instance for notifications, e.g. telegram.0",
			"default": "telegram.0",
			"newLine": true,
			"hidden": "!data.enableChargingMonitoring && !data.enableSmartChargingNotification"
		},
		"telegramUser": {
			"type": "text",
			"label": "telegramUser",
			"help": "Telegram username (empty = default user)",
			"default": "",
			"hidden": "!data.enableChargingMonitoring && !data.enableSmartChargingNotification"
		},
		"signalInstance": {
			"type": "text",
			"label": "signalInstance",
			"help": "Signal adapter instance for notifications, e.g. signal-cmb.0",
			"default": "",
			"newLine": true,
			"hidden": "!data.enableChargingMonitoring"
		},
		"evccLoadpointIndex": {
			"type": "number",
			"min": 0,
			"label": "evccLoadpointIndex",
			"help": "evcc loadpoint index to monitor (usually 0)",
			"default": 0,
			"hidden": "!data.enableChargingMonitoring"
		}
	}
}
