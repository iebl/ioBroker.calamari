{
  "name": "iobroker.calamari",
  "version": "1.2.0",
  "description": "Octopus DE API",
  "author": {
    "name": "huepfman",
    "email": "trammer@iebl.de"
  },
  "homepage": "https://github.com/huepfman/ioBroker.calamari",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "octopus",
    "api"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/iebl/ioBroker.calamari.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@iobroker/adapter-core": "^3.3.2",
    "axios": "^1.15.2",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/testing": "^5.2.2",
    "@release-it/conventional-changelog": "^11.0.0",
    "@tsconfig/node20": "^20.1.9",
    "@types/chai": "^4.3.20",
    "@types/chai-as-promised": "^7.1.8",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.0",
    "@types/proxyquire": "^1.3.31",
    "@types/sinon": "^21.0.1",
    "@types/sinon-chai": "^4.0.0",
    "chai": "^4.5.0",
    "chai-as-promised": "^7.1.2",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.3",
    "proxyquire": "^2.1.3",
    "sinon": "^21.1.2",
    "sinon-chai": "^3.7.0",
    "typescript": "~5.8.3"
  },
  "main": "main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "lib/",
    "www/",
    "io-package.json",
    "LICENSE",
    "main.js"
  ],
  "scripts": {
    "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "test:consumption": "node test-consumption-analyzer.js",
    "test:history": "node test-history-direct.js",
    "demo:ai": "node test-ai-mode-demo.js",
    "dev": "npx dev-server",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint .",
    "translate": "translate-adapter",
    "release": "release-script patch --yes",
    "release-minor": "release-script minor --yes",
    "release-major": "release-script major --yes"
  },
  "bugs": {
    "url": "https://github.com/huepfman/ioBroker.calamari/issues"
  },
  "readmeFilename": "README.md"
}
